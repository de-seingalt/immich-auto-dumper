# immich-auto-dumper — configuration
# Copy this file to config.conf and fill in the values,
# or use: immich-auto-dumper setup

# --- Immich ---
IMMICH_UPLOAD_LOCATION="/path/to/immich/upload"  # Host path to UPLOAD_LOCATION
IMMICH_DB_LIBRARY_PREFIX="/data/library"         # Absolute prefix of "originalPath" in the DB
                                                 # (auto-detected by setup; default: /data/library)
IMMICH_DB_CONTAINER="immich_postgres"
IMMICH_SERVER_CONTAINER="immich_server"
IMMICH_DB_NAME="immich"
IMMICH_DB_USER="postgres"

# --- External storage ---
# Host path of the external storage, mounted inside the immich_server container.
ARCHIVE_DEST_PATH="/mnt/external"
# Same path as seen from the Docker container.
ARCHIVE_CONTAINER_PATH="/external"
# Storage identity marker. Generated by "setup" and written both here and to
# $ARCHIVE_DEST_PATH/.immich-auto-dumper.id on the storage itself. Used to verify
# the storage is actually reachable (any type: local, OS mount, rclone/NFS, etc.)
# before writing. Leave empty; setup fills it in.
ARCHIVE_STORAGE_ID=""
# DB backups will be placed in : $ARCHIVE_DEST_PATH/.immich-backup/
# Archived photos will be in   : $ARCHIVE_DEST_PATH/<FolderName>/...

# --- Archive boundaries (library size, in MiB; 1 GiB = 1024 MiB) ---
# Driven by the actual size of UPLOAD_LOCATION/library (not whole-disk usage).
# `setup` accepts GB, MB or a percentage of the disk (e.g. 200, 1.5G, 500M, 80%)
# and stores the result here in MiB, so fractional-GB limits are possible.
# (The older ARCHIVE_LIBRARY_MAX_GB / ARCHIVE_LIBRARY_TARGET_GB keys are still
#  honored for backward compatibility if the *_MB keys are absent.)
ARCHIVE_LIBRARY_MAX_MB=204800      # archiving starts when library/ exceeds this (=200 GiB)
ARCHIVE_LIBRARY_TARGET_MB=153600   # archiving runs until library/ drops to this (=150 GiB)

# --- DB backup ---
BACKUP_RETENTION=14                # Number of backup files to keep

# --- User → external folder mapping ---
# Generated automatically by "setup"; can be edited manually.
# Key: storageLabel (or UUID if storageLabel is empty).
declare -A USER_MAP
# USER_MAP["alice"]="Alice"
# USER_MAP["bob"]="Bob"

# --- Logs ---
# Must be writable by the user running the tool (no sudo). Defaults to the XDG
# state dir when unset.
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/immich-auto-dumper"
LOG_MAX_LINES=1000
