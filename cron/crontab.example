# immich-auto-dumper — cron template.
# Do NOT install this verbatim: run `immich-auto-dumper start`, which substitutes
# __BIN__ (the installed binary path) and __LOGDIR__ (your configured LOG_DIR).

# Photo archiving (daily at 02:00)
0 2 * * * __BIN__ dump_now >> __LOGDIR__/cron.log 2>&1

# DB backup copy (weekly, Sunday 03:00)
0 3 * * 0 __BIN__ sync_now >> __LOGDIR__/cron.log 2>&1
